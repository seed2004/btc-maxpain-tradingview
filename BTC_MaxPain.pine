//@version=6
indicator("BTC Max Pain (Deribit)", "Max Pain", overlay = true, max_lines_count = 100, max_labels_count = 100)

// Generated by maxpain.py on 2026-07-16 11:54 UTC  (underlying ~ $64,425)
// Each line = Max Pain of one expiry, drawn from the last bar to its settlement time (08:00 UTC).
// Each expiry gets its own color; the label sits at the LEFT end of the line.
// Line width scales with total OI of that expiry.
//
// DAILY UPDATE -- no code edits needed:
//   run:  python maxpain.py --top 8 --clip      (or double-click update_maxpain.bat)
//   then: indicator Settings > paste (Ctrl+V) into the "Data" field.
//
// Note: on intraday timeframes TradingView clamps drawings ~500 bars into the future,
// so far expiries may appear closer than they are -- use the D or W timeframe for the full picture.

dataStr     = input.text_area("260717:63000:19506,260724:63000:12546,260731:64000:117241,260828:62000:32542,260925:72000:90100,261225:70000:90145,270326:65000:23330,270625:60000:3581", "Data (YYMMDD:maxpain:oi, comma-separated)")
showOI      = input.bool(true, "Show total OI in label")
hideExpired = input.bool(true, "Hide expired")

var string[] monthNames = array.from("JAN", "FEB", "MAR", "APR", "MAY", "JUN", "JUL", "AUG", "SEP", "OCT", "NOV", "DEC")
var color[]  palette    = array.from(color.orange, color.aqua, color.lime, color.fuchsia, color.yellow, color.red, color.teal, color.purple)

var line[]  lns = array.new<line>()
var label[] lbs = array.new<label>()

if barstate.islast
    for l in lns
        line.delete(l)
    for lb in lbs
        label.delete(lb)
    array.clear(lns)
    array.clear(lbs)
    items = str.split(dataStr, ",")
    float maxOi = 0.0
    for it in items
        p = str.split(str.trim(it), ":")
        if array.size(p) == 3
            maxOi := math.max(maxOi, nz(str.tonumber(array.get(p, 2))))
    float[] usedPx = array.new<float>()
    int drawn = 0
    for it in items
        p = str.split(str.trim(it), ":")
        if array.size(p) == 3
            d  = int(nz(str.tonumber(array.get(p, 0))))
            px = nz(str.tonumber(array.get(p, 1)))
            oi = nz(str.tonumber(array.get(p, 2)))
            yy = d / 10000
            mm = d / 100 % 100
            dd = d % 100
            expT = timestamp("UTC", 2000 + yy, mm, dd, 8, 0)
            if not hideExpired or expT > time
                col = array.get(palette, drawn % array.size(palette))
                drawn += 1
                w = oi >= 0.5 * maxOi ? 3 : oi >= 0.15 * maxOi ? 2 : 1
                array.push(lns, line.new(time, px, expT, px, xloc = xloc.bar_time, color = col, style = line.style_dashed, width = w))
                // labels sit at the LEFT end of each line; when several expiries share the same
                // max pain price, each duplicate is nudged further left so labels don't overlap
                dup = 0
                for u in usedPx
                    if u == px
                        dup += 1
                array.push(usedPx, px)
                lx = time - dup * 30 * timeframe.in_seconds() * 1000
                expName = (dd < 10 ? "0" : "") + str.tostring(dd) + array.get(monthNames, mm - 1) + str.tostring(yy)
                txt = expName + "  " + str.tostring(px, "#")
                if showOI
                    txt := txt + "  |  OI " + str.tostring(oi, "#") + " BTC"
                array.push(lbs, label.new(lx, px, txt, xloc = xloc.bar_time, style = label.style_label_right, color = color.new(col, 85), textcolor = col, size = size.small))
